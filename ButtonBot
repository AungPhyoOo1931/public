<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Button Bot 按钮编辑器</title>
  <style>
    :root {
      --bg: #0f1419;
      --surface: #1a2332;
      --surface2: #243044;
      --border: #2f4058;
      --text: #e8eef5;
      --muted: #8fa3bd;
      --primary: #3b82f6;
      --primary-hover: #2563eb;
      --success: #22c55e;
      --danger: #ef4444;
      --radius: 12px;
      --header-h: 52px;
      --tabbar-h: 56px;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC",
        "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
      padding-top: var(--header-h);
      padding-bottom: calc(var(--tabbar-h) + var(--safe-bottom));
    }

    .app-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--header-h);
      padding: 0 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(15, 20, 25, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      z-index: 50;
    }

    .app-header h1 {
      font-size: 1rem;
      font-weight: 700;
    }

    .help-btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      width: 32px;
      height: 32px;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 700;
      cursor: pointer;
    }

    .wrap {
      max-width: 720px;
      margin: 0 auto;
      padding: 12px 12px 16px;
    }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .tab-bar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      height: calc(var(--tabbar-h) + var(--safe-bottom));
      padding-bottom: var(--safe-bottom);
      display: flex;
      background: rgba(26, 35, 50, 0.96);
      backdrop-filter: blur(12px);
      border-top: 1px solid var(--border);
      z-index: 50;
    }

    .tab-bar button {
      flex: 1;
      border: none;
      background: transparent;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 600;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    .tab-bar button .icon { font-size: 1.15rem; line-height: 1; }
    .tab-bar button.active { color: var(--primary); }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 10px;
    }

    .panel-head h2 {
      font-size: 0.95rem;
      font-weight: 600;
    }

    .hint {
      color: var(--muted);
      font-size: 0.8rem;
      margin-bottom: 10px;
    }

    .row-tabs {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      margin-bottom: 12px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .row-tabs::-webkit-scrollbar { display: none; }

    .row-tab {
      flex-shrink: 0;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
    }

    .row-tab.active {
      background: rgba(59, 130, 246, 0.18);
      border-color: var(--primary);
      color: var(--primary);
    }

    .row-tab.add {
      color: var(--text);
      min-width: 40px;
      text-align: center;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
    }

    .btn-item {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px;
      margin-bottom: 8px;
    }

    .btn-item:last-child { margin-bottom: 0; }

    .btn-item-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
    }

    .field { margin-bottom: 8px; }
    .field:last-child { margin-bottom: 0; }

    label {
      display: block;
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 4px;
    }

    input[type="text"],
    input[type="url"],
    textarea {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
      color: var(--text);
      font-size: 16px;
      outline: none;
    }

    input:focus, textarea:focus { border-color: var(--primary); }

    textarea {
      resize: vertical;
      min-height: 64px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 13px;
      line-height: 1.4;
    }

    .color-group {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .color-option input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .color-option span {
      display: block;
      text-align: center;
      padding: 8px 4px;
      border-radius: 8px;
      border: 2px solid var(--border);
      font-size: 0.75rem;
      cursor: pointer;
      user-select: none;
    }

    .color-option input:checked + span {
      border-color: var(--primary);
      background: rgba(59, 130, 246, 0.15);
    }

    .color-option.p span { color: #60a5fa; }
    .color-option.s span { color: #4ade80; }
    .color-option.d span { color: #f87171; }

    .toolbar {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .toolbar button { flex: 1; }

    button {
      border: none;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    button:active { transform: scale(0.98); }
    button:disabled { opacity: 0.4; cursor: not-allowed; }

    .btn-primary { background: var(--primary); color: #fff; }
    .btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
    .btn-danger { background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.35); }
    .btn-small { padding: 7px 10px; font-size: 0.78rem; }

    .copy-preview {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
    }

    .copy-preview textarea {
      min-height: 120px;
      max-height: 40vh;
    }

    .copy-status {
      text-align: center;
      font-size: 0.88rem;
      color: var(--success);
      font-weight: 600;
      margin-bottom: 10px;
    }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.55);
      z-index: 80;
      display: none;
      align-items: flex-end;
      justify-content: center;
      padding: 16px;
      padding-bottom: calc(16px + var(--safe-bottom));
    }

    .overlay.show { display: flex; }

    .sheet {
      width: 100%;
      max-width: 480px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px 16px 12px 12px;
      padding: 16px;
    }

    .sheet h3 {
      font-size: 1rem;
      margin-bottom: 10px;
    }

    .sheet ol {
      padding-left: 18px;
      color: var(--muted);
      font-size: 0.88rem;
      display: grid;
      gap: 8px;
    }

    .sheet-close {
      width: 100%;
      margin-top: 14px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: calc(var(--tabbar-h) + 12px + var(--safe-bottom));
      transform: translateX(-50%) translateY(12px);
      background: var(--success);
      color: #fff;
      padding: 9px 16px;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s, transform 0.2s;
      z-index: 100;
      max-width: 90vw;
      text-align: center;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    @media (min-width: 640px) {
      body { padding-top: 60px; }

      .app-header { height: 60px; padding: 0 24px; }
      .app-header h1 { font-size: 1.15rem; }

      .wrap { padding: 16px 24px 24px; }

      .tab-bar {
        position: static;
        height: auto;
        padding: 0;
        margin-bottom: 16px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--surface);
      }

      body { padding-bottom: 24px; }

      .tab-bar button {
        flex-direction: row;
        gap: 6px;
        padding: 12px;
        font-size: 0.9rem;
      }

      .toast { bottom: 24px; }

      .overlay { align-items: center; }

      .btn-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      .btn-grid .field-full { grid-column: 1 / -1; }
    }
  </style>
</head>
<body>
  <header class="app-header">
    <h1>Button Bot 编辑器</h1>
    <button type="button" class="help-btn" id="helpBtn" aria-label="帮助">?</button>
  </header>

  <div class="wrap">
    <nav class="tab-bar" id="tabBar">
      <button type="button" class="active" data-tab="edit"><span class="icon">✏️</span><span>编辑</span></button>
      <button type="button" data-tab="copy"><span class="icon">📋</span><span>复制</span></button>
      <button type="button" data-tab="import"><span class="icon">📥</span><span>导入</span></button>
    </nav>

    <section class="tab-panel active" id="panel-edit">
      <p class="hint">每排最多 5 个 · 最多 10 排</p>
      <div class="row-tabs" id="rowTabs"></div>
      <div class="card" id="rowsContainer"></div>
      <div class="toolbar">
        <button type="button" class="btn-secondary" id="addBtnInRow">+ 本排按钮</button>
        <button type="button" class="btn-danger" id="removeRowBtn">删除本排</button>
      </div>
    </section>

    <section class="tab-panel" id="panel-copy">
      <p class="hint">点「复制」Tab 会自动复制全部，回到 Bot 发 /setbuttons 后粘贴</p>
      <div class="copy-status" id="copyStatus"></div>
      <div class="copy-preview">
        <textarea id="copyPreview" readonly rows="8"></textarea>
      </div>
      <div class="toolbar">
        <button type="button" class="btn-primary" id="copyAllBtn">再次复制</button>
      </div>
    </section>

    <section class="tab-panel" id="panel-import">
      <p class="hint">粘贴 /buttons 或 /format 的内容</p>
      <textarea id="importText" rows="6" placeholder="1.[p-名字-https://example.com]&#10;2.[名字-https://example.com]"></textarea>
      <div class="toolbar">
        <button type="button" class="btn-primary" id="importBtn">导入</button>
        <button type="button" class="btn-danger" id="clearBtn">清空</button>
      </div>
    </section>
  </div>

  <div class="overlay" id="helpOverlay">
    <div class="sheet">
      <h3>使用说明</h3>
      <ol>
        <li>从 Telegram Bot 发送 /editor 下载本文件，用浏览器打开</li>
        <li>在「编辑」里添加按钮，设置名字、链接和颜色</li>
        <li>点「复制」Tab 自动复制全部</li>
        <li>回到 Bot 发送 /setbuttons，粘贴即可</li>
      </ol>
      <button type="button" class="btn-primary sheet-close" id="helpClose">知道了</button>
    </div>
  </div>

  <div class="toast" id="toast">已复制</div>

  <script>
    const MAX_BUTTONS_PER_ROW = 5;
    const MAX_ROWS = 10;

    let rows = [[{ text: '名字', url: 'https://example.com', color: '' }]];
    let activeTab = 'edit';
    let activeRow = 0;

    const rowTabs = document.getElementById('rowTabs');
    const rowsContainer = document.getElementById('rowsContainer');
    const copyPreview = document.getElementById('copyPreview');
    const copyStatus = document.getElementById('copyStatus');
    const toast = document.getElementById('toast');

    function showToast(text, isError) {
      toast.textContent = text;
      toast.style.background = isError ? 'var(--danger)' : 'var(--success)';
      toast.classList.add('show');
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => toast.classList.remove('show'), 1800);
    }

    function renderCopyPreview() {
      copyPreview.value = formatAllRows();
    }

    async function copyAll(silent) {
      const text = formatAllRows();
      renderCopyPreview();

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        copyPreview.select();
        document.execCommand('copy');
      }

      copyStatus.textContent = '已复制全部';
      if (!silent) showToast('已复制全部');
    }

    function formatButton(btn) {
      const prefix = btn.color ? `${btn.color}-` : '';
      return `[${prefix}${btn.text}-${btn.url}]`;
    }

    function formatRow(rowIndex, row) {
      const buttons = row.map(formatButton).join(',');
      const suffix = rowIndex < rows.length - 1 ? ',' : '';
      return `${rowIndex + 1}.${buttons}${suffix}`;
    }

    function formatAllRows() {
      return rows.map((row, i) => formatRow(i, row)).join('\n');
    }

    function parseButtonItem(content) {
      let rest = content.trim();
      let color = '';
      const colorMatch = rest.match(/^([psd])-(.+)$/i);
      if (colorMatch) {
        color = colorMatch[1].toLowerCase();
        rest = colorMatch[2];
      }
      const match = rest.match(/^(.+?)-(https?:\/\/.+)$/i);
      if (!match) throw new Error(`格式错误: ${content}`);
      return { text: match[1].trim(), url: match[2].trim(), color };
    }

    function parseFormatText(text) {
      const trimmed = text.trim();
      if (!trimmed) throw new Error('内容为空');

      const rowSegments = trimmed.includes('\n')
        ? trimmed.split('\n').map((l) => l.trim()).filter(Boolean)
        : trimmed.split(/,\s*(?=\d+\.)/);

      const parsed = rowSegments.map((segment, index) => {
        const rowMatch = segment.match(/^(\d+)\.(.*)$/);
        if (!rowMatch) throw new Error('每排需以数字开头');

        const rowNum = Number(rowMatch[1]);
        if (rowNum !== index + 1) throw new Error(`排号应为 ${index + 1}`);

        const bracketMatches = [...rowMatch[2].matchAll(/\[([^\]]+)\]/g)];
        if (!bracketMatches.length) throw new Error(`第 ${rowNum} 排没有按钮`);
        if (bracketMatches.length > MAX_BUTTONS_PER_ROW) {
          throw new Error(`第 ${rowNum} 排最多 ${MAX_BUTTONS_PER_ROW} 个`);
        }
        return bracketMatches.map((m) => parseButtonItem(m[1]));
      });

      if (parsed.length > MAX_ROWS) throw new Error(`最多 ${MAX_ROWS} 排`);
      return parsed;
    }

    function escapeAttr(str) {
      return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
    }

    function renderColorRadios(rowIndex, btnIndex, color) {
      const name = `color-${rowIndex}-${btnIndex}`;
      const options = [
        { value: '', label: '默认' },
        { value: 'p', label: '蓝' },
        { value: 's', label: '绿' },
        { value: 'd', label: '红' },
      ];
      return options.map((opt) => `
        <label class="color-option ${opt.value || 'none'}">
          <input type="radio" name="${name}" value="${opt.value}" ${color === opt.value ? 'checked' : ''}
            data-row="${rowIndex}" data-btn="${btnIndex}" data-field="color">
          <span>${opt.label}</span>
        </label>
      `).join('');
    }

    function renderRowTabs() {
      const tabs = rows.map((_, i) => `
        <button type="button" class="row-tab ${i === activeRow ? 'active' : ''}" data-row-tab="${i}">
          第 ${i + 1} 排
        </button>
      `).join('');

      const addBtn = rows.length < MAX_ROWS
        ? `<button type="button" class="row-tab add" id="addRowTab">+</button>`
        : '';

      rowTabs.innerHTML = tabs + addBtn;

      rowTabs.querySelectorAll('[data-row-tab]').forEach((el) => {
        el.addEventListener('click', () => {
          activeRow = Number(el.dataset.rowTab);
          renderCurrentRow();
          renderRowTabs();
        });
      });

      const addRowTab = document.getElementById('addRowTab');
      if (addRowTab) {
        addRowTab.addEventListener('click', () => {
          rows.push([{ text: '名字', url: 'https://example.com', color: '' }]);
          activeRow = rows.length - 1;
          render();
        });
      }
    }

    function renderCurrentRow() {
      if (activeRow >= rows.length) activeRow = rows.length - 1;
      const row = rows[activeRow];
      if (!row) return;

      rowsContainer.innerHTML = row.map((btn, btnIndex) => `
        <div class="btn-item">
          <div class="btn-item-head">
            <span>按钮 ${btnIndex + 1}</span>
            <button type="button" class="btn-danger btn-small" data-action="remove-btn" data-btn="${btnIndex}"
              ${row.length <= 1 ? 'disabled' : ''}>删除</button>
          </div>
          <div class="btn-grid">
            <div class="field">
              <label>名字</label>
              <input type="text" value="${escapeAttr(btn.text)}" data-btn="${btnIndex}" data-field="text">
            </div>
            <div class="field">
              <label>链接</label>
              <input type="url" inputmode="url" value="${escapeAttr(btn.url)}" data-btn="${btnIndex}" data-field="url">
            </div>
            <div class="field field-full">
              <label>颜色</label>
              <div class="color-group">${renderColorRadios(activeRow, btnIndex, btn.color)}</div>
            </div>
          </div>
        </div>
      `).join('');

      document.getElementById('addBtnInRow').disabled = row.length >= MAX_BUTTONS_PER_ROW;
      document.getElementById('removeRowBtn').disabled = rows.length <= 1;

      bindRowEvents();
    }

    function renderOutput() {
      renderCopyPreview();
    }

    function bindRowEvents() {
      rowsContainer.querySelectorAll('input[data-field="text"], input[data-field="url"]').forEach((el) => {
        el.addEventListener('input', (e) => {
          const btn = Number(e.target.dataset.btn);
          rows[activeRow][btn][e.target.dataset.field] = e.target.value;
          renderOutput();
        });
      });

      rowsContainer.querySelectorAll('input[data-field="color"]').forEach((el) => {
        el.addEventListener('change', (e) => {
          const btn = Number(e.target.dataset.btn);
          rows[activeRow][btn].color = e.target.value;
          renderOutput();
        });
      });

      rowsContainer.querySelectorAll('[data-action="remove-btn"]').forEach((el) => {
        el.addEventListener('click', () => {
          const btn = Number(el.dataset.btn);
          if (rows[activeRow].length > 1) {
            rows[activeRow].splice(btn, 1);
            render();
          }
        });
      });
    }

    function render() {
      renderRowTabs();
      renderCurrentRow();
      renderOutput();
    }

    function switchTab(tab) {
      activeTab = tab;
      document.querySelectorAll('.tab-bar button').forEach((el) => {
        el.classList.toggle('active', el.dataset.tab === tab);
      });
      document.querySelectorAll('.tab-panel').forEach((el) => {
        el.classList.toggle('active', el.id === `panel-${tab}`);
      });
      if (tab === 'copy') copyAll(true);
    }

    document.getElementById('tabBar').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-tab]');
      if (btn) switchTab(btn.dataset.tab);
    });

    document.getElementById('addBtnInRow').addEventListener('click', () => {
      if (rows[activeRow].length < MAX_BUTTONS_PER_ROW) {
        rows[activeRow].push({ text: '名字', url: 'https://example.com', color: '' });
        render();
      }
    });

    document.getElementById('removeRowBtn').addEventListener('click', () => {
      if (rows.length <= 1) return;
      rows.splice(activeRow, 1);
      if (activeRow >= rows.length) activeRow = rows.length - 1;
      render();
    });

    document.getElementById('copyAllBtn').addEventListener('click', () => copyAll(false));

    document.getElementById('importBtn').addEventListener('click', () => {
      try {
        rows = parseFormatText(document.getElementById('importText').value);
        activeRow = 0;
        render();
        switchTab('edit');
        showToast('导入成功');
      } catch (err) {
        showToast(err.message, true);
      }
    });

    document.getElementById('clearBtn').addEventListener('click', () => {
      if (confirm('确定清空？')) {
        rows = [[{ text: '名字', url: 'https://example.com', color: '' }]];
        activeRow = 0;
        document.getElementById('importText').value = '';
        render();
      }
    });

    document.getElementById('helpBtn').addEventListener('click', () => {
      document.getElementById('helpOverlay').classList.add('show');
    });

    document.getElementById('helpClose').addEventListener('click', () => {
      document.getElementById('helpOverlay').classList.remove('show');
    });

    document.getElementById('helpOverlay').addEventListener('click', (e) => {
      if (e.target.id === 'helpOverlay') {
        document.getElementById('helpOverlay').classList.remove('show');
      }
    });

    render();
  </script>
</body>
</html>
